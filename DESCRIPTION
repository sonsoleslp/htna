Package: htna
Title: Heterogeneous Transition Network Analysis
Version: 0.1.0
Authors@R: c(
    person("Sonsoles", "L\u00f3pez-Pernas", email = "sonsoles.lopez@uef.fi",
           role = c("aut", "cre", "cph")),
    person("Kamila", "Misiejuk", role = c("aut", "cph")),
